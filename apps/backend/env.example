# --- Server ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# --- CORS ---
# Comma-separated list of allowed origins (frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Firebase Admin ---
# Use ONE of:
# (1) Local dev — paste the full service-account JSON as a single line:
FIREBASE_SERVICE_ACCOUNT_JSON=
# (2) CI / Cloud Run — leave the above empty and set GOOGLE_APPLICATION_CREDENTIALS
#     or rely on Application Default Credentials (workload identity).
# For local dev, run `gcloud auth application-default login` and leave the
# JSON blank — ADC will pick up your user credentials.

# Firebase project id (required when no service-account JSON is supplied)
FIREBASE_PROJECT_ID=muga-staging

# Firebase Storage bucket — we use a custom-named bucket because
# .appspot.com and .firebasestorage.app require domain verification.
# Staging:    muga-staging-cover-art
# Production: muga-production-cover-art
FIREBASE_STORAGE_BUCKET=muga-staging-cover-art

# --- Auth ---
# Initial admin emails (comma-separated). On first sign-in these accounts will
# automatically receive the `role: admin` custom claim.
# In production/staging this is mounted from Secret Manager `initial-admin-emails`.
INITIAL_ADMIN_EMAILS=

# --- Sentry ---
# Get DSNs from https://sentry.io/ → muga-backend project → Settings → Client Keys
# Mounted from Secret Manager `sentry-dsn-backend` in staging/production.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# --- Firebase Emulators (local only) ---
# Set to non-empty to point Admin SDK at local emulators
FIRESTORE_EMULATOR_HOST=
FIREBASE_AUTH_EMULATOR_HOST=
FIREBASE_STORAGE_EMULATOR_HOST=

# --- Alerting (see docs/api/alerting-runbook.md) ---
# Slack incoming-webhook URL for #muga-alerts
# Mounted from Secret Manager `slack-webhook-url` in staging/production.
SLACK_WEBHOOK_URL=
# Optional: PagerDuty Events v2 integration key (production only)
# Mounted from Secret Manager `pagerduty-integration-key` in production.
PAGERDUTY_INTEGRATION_KEY=
# Optional: comma-separated list of email recipients for fallback alerts
ALERT_EMAIL_RECIPIENTS=
# Threshold (in milliseconds) above which a /healthz/ready ping is logged as alert
ALERT_READY_LATENCY_BUDGET_MS=2000

# Copy this file to .env. Never commit .env — it's in .gitignore.
# Use `scripts/setup-local-env.sh` for an interactive walkthrough.
