# --- API ---
# Server-only SSR API base. In Cloud Run this should point directly to the
# backend Cloud Run URL so server-rendered pages can forward __session without
# going through Firebase Hosting rewrites.
API_URL=http://localhost:3001

# Browser API base. Public client calls may go through Hosting /api rewrites.
# NEXT_PUBLIC_* is the only supported browser env prefix for the Next.js app.
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Firebase web config ---
# Values for muga-staging / muga-production are baked into deploy-*.yml
# (pulled from Secret Manager at build time). For LOCAL dev, copy the staging
# values below — these are the actual keys from your provisioned projects.
#
# STAGING (safe to commit to local .env — these are public client-side
# credentials, domain-restricted by Firebase Auth):
#   API_KEY:     AIzaSyDXT-A5PCyAW39kK8LLNWeUKEaGeEWlrio
#   AUTH_DOMAIN: muga-staging.firebaseapp.com
#   PROJECT_ID:  muga-staging
#   APP_ID:      1:438419642765:web:64ee9c4956469a129945c4
#   BUCKET:      muga-staging-cover-art
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Sentry ---
# Get DSN from https://sentry.io/ → muga-frontend project → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Locales ---
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,nl

# --- Build ---
NEXT_PUBLIC_APP_VERSION=0.1.0

# Copy this file to .env.local. Never commit .env.local.
# Use `scripts/setup-local-env.sh` for an interactive walkthrough.
