# --- API ---
VITE_API_URL=http://localhost:3001

# --- Firebase web config ---
# Values for muga-staging / muga-production are baked into deploy-*.yml
# (pulled from Secret Manager at build time). For LOCAL dev, copy the staging
# values below — these are the actual keys from your provisioned projects.
#
# STAGING (safe to commit to local .env — these are public client-side
# credentials, domain-restricted by Firebase Auth):
#   API_KEY:     AIzaSyDXT-A5PCyAW39kK8LLNWeUKEaGeEWlrio
#   AUTH_DOMAIN: muga-staging.firebaseapp.com
#   PROJECT_ID:  muga-staging
#   APP_ID:      1:438419642765:web:64ee9c4956469a129945c4
#   BUCKET:      muga-staging-cover-art
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Sentry ---
# Get DSN from https://sentry.io/ → muga-frontend project → Settings → Client Keys
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Locales ---
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,nl

# --- Build ---
VITE_APP_VERSION=0.1.0

# Copy this file to .env.local. Never commit .env.local.
# Use `scripts/setup-local-env.sh` for an interactive walkthrough.
