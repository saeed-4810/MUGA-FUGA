    "preview": "mkdir -p .next/standalone/apps/frontend/.next && cp -R public .next/standalone/apps/frontend/public && cp -R .next/static .next/standalone/apps/frontend/.next/static && PORT=${PORT:-5174} HOSTNAME=0.0.0.0 node .next/standalone/apps/frontend/server.js",
