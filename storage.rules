rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() { return request.auth != null; }
    function isAdmin()  { return signedIn() && request.auth.token.role == 'admin'; }

    // Cover-art objects:
    //   path: cover-art/{uid}/{filename}
    //
    // - Anyone signed-in can read (CDN serves with public Hosting rewrites in
    //   production via signed/object URLs returned by the backend).
    // - Owner uploads use signed URLs (PUT) generated by the backend, which
    //   bypass these rules. We still allow direct PUT from the owner as a
    //   defense-in-depth fallback if signing flow is unavailable.
    match /cover-art/{uid}/{file=**} {
      allow read: if signedIn() || isAdmin();
      allow write: if isAdmin() || (signedIn() && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|avif)'));
    }

    // Artist images (ADR-007 — Sprint 2):
    //   path: artist-images/{uid}/{filename}
    //
    // Same policy as cover art — backend signed URL is the primary path,
    // direct owner PUT works as defense-in-depth. Read is signed-in only
    // (artists with status=published are publicly listable via /api/artists,
    // but the image URL itself is short-lived; renderers fetch via the
    // backend-issued signed read URL or the Firebase Hosting CDN).
    match /artist-images/{uid}/{file=**} {
      allow read: if signedIn() || isAdmin();
      allow write: if isAdmin() || (signedIn() && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|avif)'));
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
